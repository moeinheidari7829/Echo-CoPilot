# OpenAI API Configuration
OPENAI_API_KEY="your-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TEMPERATURE="0.7"
OPENAI_MAX_TOKENS="1000"

# Alternative: OpenRouter
# OPENAI_API_KEY="your-openrouter-key"
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_MODEL="openai/gpt-oss-120b"

# Alternative: Groq
# OPENAI_API_KEY="your-groq-key"
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="openai/gpt-oss-120b"

# Contrast LLM (for self-contrast)
CONTRAST_LLM_MODEL="gpt-4o-mini"

# Video Configuration
VIDEO_PATH="path/to/your/video.mp4"

# Model Configuration
DEVICE="cuda"  # or "cpu"
MEASUREMENT_TOOL="echoprime"  # or "echonet" or "both"

# Self-Contrast
USE_SELF_CONTRAST="true"

# SAM2 Configuration
SAM2_CONFIG_DIR="./tool_repos/MedSAM2-main/sam2/configs"
ECHO_SAM2_MODEL_CFG="sam2.1_hiera_t512.yaml"
ECHO_INITIAL_MASK_PATH="./tool_repos/MedSAM2-main/default_masks/LV.png"
